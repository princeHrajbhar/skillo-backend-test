# ─── Server ──────────────────────────────────────────────────────────────────
# Render injects PORT automatically; locally defaults to 5000.
PORT=5000
NODE_ENV=production

# ─── Database ────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:pass@cluster0.mongodb.net/skillo

# ─── JWT secrets (use long random strings) ───────────────────────────────────
JWT_ACCESS_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ─── CORS / Frontend ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash).
# In production set this to your Vercel URL.
FRONTEND_URL=https://your-frontend.vercel.app,http://localhost:3000

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Admin seed (used by `npm run seed`) ─────────────────────────────────────
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeThisStrongPass123!
